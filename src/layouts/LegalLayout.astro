---
import BaseLayout from "./BaseLayout.astro";

const { title, description, lastUpdated } = Astro.props;
const currentLocale = Astro.currentLocale ?? 'ru';

const switchPath = (target: 'ru' | 'en') => {
  const currentPath = Astro.url.pathname;
  return currentPath.replace(/^\/(ru|en)/, `/${target}`);
};

const backToHomeText = currentLocale === 'ru' ? 'Вернуться на главную' : 'Back to Home';
const lastUpdatedText = currentLocale === 'ru' ? 'Последнее обновление' : 'Last updated';
---

<BaseLayout title={title} description={description}>
  <main class="min-h-screen bg-neutral-950 text-neutral-200 font-sans">
    <!-- Шапка -->
    <header class="border-b border-neutral-900 bg-neutral-900/20">
      <div class="mx-auto max-w-5xl px-4 py-16 md:py-20">
        <div class="flex flex-col md:flex-row md:items-center justify-between gap-8 mb-8">
          <nav>
            <a href={`/${currentLocale}`} class="text-[10px] font-bold uppercase tracking-[0.2em] text-neutral-500 hover:text-white transition-colors inline-flex items-center gap-2 group">
              <svg class="w-3 h-3 transition-transform group-hover:-translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
              </svg>
              {backToHomeText}
            </a>
          </nav>
          
          <div class="flex items-center gap-1 text-[10px] font-bold bg-neutral-900/50 rounded-none border border-neutral-800 p-1 w-fit">
            <a href={switchPath('ru')} class={`px-3 py-1.5 rounded-none ${currentLocale === 'ru' ? 'bg-white text-neutral-950' : 'text-neutral-500 hover:text-white transition-colors'}`}>RU</a>
            <span class="text-neutral-800 px-1">/</span>
            <a href={switchPath('en')} class={`px-3 py-1.5 rounded-none ${currentLocale === 'en' ? 'bg-white text-neutral-950' : 'text-neutral-500 hover:text-white transition-colors'}`}>EN</a>
          </div>
        </div>
        <h1 class="text-4xl md:text-6xl font-black uppercase tracking-tight text-white mb-4 leading-none">
          {title.split(' - ')[0]}
        </h1>
        <p class="text-neutral-600 text-[10px] font-bold uppercase tracking-[0.2em]">
          {lastUpdatedText}: {lastUpdated}
        </p>
      </div>
    </header>

    <div class="mx-auto max-w-4xl px-4 py-12 md:py-16">
      <div class="legal-content prose prose-invert prose-neutral max-w-none 
        prose-p:text-neutral-400 prose-p:leading-relaxed prose-p:text-lg
        prose-strong:text-white prose-strong:font-bold
        prose-a:text-white prose-a:no-underline prose-a:border-b prose-a:border-neutral-700 hover:prose-a:border-white transition-colors
        prose-hr:border-neutral-900">
        <slot />
      </div>
    </div>

<style is:global>
  /* Фиксы для кастомных компонентов внутри prose */
  .legal-content .heading-wrapper {
    margin-top: 2.5rem;
    margin-bottom: 1.5rem;
  }
  .legal-content .heading-wrapper:first-child {
    margin-top: 0;
  }
  .legal-content ul, .legal-content ol {
    margin-top: 1.5rem;
    margin-bottom: 1.5rem;
  }
</style>

    <footer class="mx-auto max-w-5xl px-4 py-16 border-t border-neutral-900 text-[10px] font-bold uppercase tracking-[0.2em] text-neutral-700 flex justify-between">
      <span>© 2026 Sect Development</span>
      <span>{currentLocale === 'ru' ? 'Все права защищены' : 'All rights reserved'}</span>
    </footer>
  </main>
</BaseLayout>
