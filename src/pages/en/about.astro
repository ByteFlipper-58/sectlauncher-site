---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
---

<BaseLayout title="About — SectLauncher" description="SectLauncher — modern Minecraft launcher built with Rust + Tauri v2 and Clean Architecture.">
  <Fragment slot="header"><Header /></Fragment>
  <Fragment slot="head">
    <link rel="canonical" href="https://sectlauncher.byteflipper.com/en/about/" />
    <link rel="alternate" hreflang="ru" href="https://sectlauncher.byteflipper.com/ru/about/" />
    <link rel="alternate" hreflang="x-default" href="https://sectlauncher.byteflipper.com/ru/about/" />
    <meta property="og:url" content="https://sectlauncher.byteflipper.com/en/about/" />
  </Fragment>

  <!-- Hero Section -->
  <section class="hero-bg">
    <div class="mx-auto max-w-6xl px-4 py-16">
      <div class="text-center max-w-4xl mx-auto">
        <h1 class="text-4xl md:text-5xl font-extrabold mb-6">
          SectLauncher
          <span class="block text-2xl md:text-3xl text-emerald-400 mt-2">An engineering approach to launchers</span>
        </h1>
        <h2 class="sr-only">About the Project</h2>
        <p class="text-xl text-neutral-300 mb-6 leading-relaxed">
          Modern Minecraft launcher built with Rust + Tauri v2, following Clean Architecture principles. Designed to be a convenient, high-performance, and secure wrapper for the game with support for vanilla and modded clients.
        </p>
        
        <div class="inline-flex items-center px-4 py-3 rounded-lg bg-orange-500/20 border border-orange-500/30 mb-8">
          <svg class="w-5 h-5 mr-3 text-orange-400" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/>
          </svg>
          <div>
            <div class="text-orange-300 font-medium text-base">Project in active development</div>
            <div class="text-orange-400 text-sm">Follow us on Telegram for updates</div>
          </div>
        </div>
        <div class="flex flex-wrap justify-center gap-4">
          <div class="px-6 py-3 rounded-lg font-semibold text-orange-900 bg-orange-500 cursor-not-allowed opacity-75 flex items-center gap-2">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/>
            </svg>
            In Development
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Development Status -->
  <section class="mx-auto max-w-6xl px-4 py-16">
    <div class="grid lg:grid-cols-2 gap-12">
      <!-- What's Ready -->
      <div>
        <h2 class="text-3xl font-bold mb-6 text-emerald-400">✅ Implemented</h2>
        <div class="space-y-4">
          <div class="flex items-start gap-3 p-4 rounded-lg bg-emerald-500/10 border border-emerald-500/20">
            <div class="w-2 h-2 rounded-full bg-emerald-500 mt-2 shrink-0"></div>
            <div>
              <h3 class="font-semibold">Microsoft/Mojang Authentication</h3>
              <p class="text-neutral-300 text-sm">Complete authentication system via official APIs</p>
            </div>
          </div>

          <div class="flex items-start gap-3 p-4 rounded-lg bg-emerald-500/10 border border-emerald-500/20">
            <div class="w-2 h-2 rounded-full bg-emerald-500 mt-2 shrink-0"></div>
            <div>
              <h3 class="font-semibold">Minecraft Downloads</h3>
              <p class="text-neutral-300 text-sm">Automatic downloading and installation of Vanilla, Fabric and Forge versions</p>
            </div>
          </div>

          <div class="flex items-start gap-3 p-4 rounded-lg bg-emerald-500/10 border border-emerald-500/20">
            <div class="w-2 h-2 rounded-full bg-emerald-500 mt-2 shrink-0"></div>
            <div>
              <h3 class="font-semibold">Instance Management</h3>
              <p class="text-neutral-300 text-sm">Creating, editing, and deleting game profiles</p>
            </div>
          </div>

          <div class="flex items-start gap-3 p-4 rounded-lg bg-emerald-500/10 border border-emerald-500/20">
            <div class="w-2 h-2 rounded-full bg-emerald-500 mt-2 shrink-0"></div>
            <div>
              <h3 class="font-semibold">Clean Architecture</h3>
              <p class="text-neutral-300 text-sm">Modular architecture with separation of concerns</p>
            </div>
          </div>

          <div class="flex items-start gap-3 p-4 rounded-lg bg-emerald-500/10 border border-emerald-500/20">
            <div class="w-2 h-2 rounded-full bg-emerald-500 mt-2 shrink-0"></div>
            <div>
              <h3 class="font-semibold">OTA Updates</h3>
              <p class="text-neutral-300 text-sm">Automatic launcher updates without user intervention</p>
            </div>
          </div>

          <div class="flex items-start gap-3 p-4 rounded-lg bg-emerald-500/10 border border-emerald-500/20">
            <div class="w-2 h-2 rounded-full bg-emerald-500 mt-2 shrink-0"></div>
            <div>
              <h3 class="font-semibold">Cross-platform</h3>
              <p class="text-neutral-300 text-sm">Full support for Windows 10/11, macOS and Linux</p>
            </div>
          </div>
        </div>
      </div>

      <!-- In Progress & Roadmap -->
      <div class="space-y-12">
        <div>
          <h2 class="text-3xl font-bold mb-6 text-blue-400">🚧 In Progress</h2>
          <div class="space-y-4">
            <div class="flex items-start gap-3 p-4 rounded-lg bg-blue-500/10 border border-blue-500/20">
              <div class="w-2 h-2 rounded-full bg-blue-500 mt-2 shrink-0"></div>
              <div>
                <h3 class="font-semibold">Modrinth & CurseForge Integration</h3>
                <p class="text-neutral-300 text-sm">Easy search and automatic installation of mods from popular services</p>
              </div>
            </div>
            
            <div class="flex items-start gap-3 p-4 rounded-lg bg-blue-500/10 border border-blue-500/20">
              <div class="w-2 h-2 rounded-full bg-blue-500 mt-2 shrink-0"></div>
              <div>
                <h3 class="font-semibold">UI/UX Polishing</h3>
                <p class="text-neutral-300 text-sm">Polishing the interface before the public release</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Developer Section -->
<section class="mx-auto max-w-6xl px-4 py-16">
  <div class="w-full max-w-none">
    <div class="rounded-2xl border border-neutral-800 bg-neutral-900/50 p-8 hover:border-neutral-700 transition-all duration-300 relative">
      <!-- Logo positioned at top-left -->
      <div class="absolute top-6 left-6 w-20 h-20 rounded-xl overflow-hidden z-10">
        <img 
          src="https://byteflipper.web.app/images/logo.png" 
          alt="ByteFlipper Logo" 
          class="w-full h-full object-cover rounded-xl shadow-lg hover:scale-105 transition-transform duration-300"
          onerror="this.style.display='none'; this.nextElementSibling.style.display='flex'"
        />
        <!-- Fallback if image fails -->
        <div class="absolute inset-0 w-20 h-20 rounded-xl grid place-items-center text-2xl font-bold text-neutral-900" style="background:linear-gradient(135deg,#ef116f,#fe6407); display: none;">
          BF
        </div>
      </div>
      
      <!-- Main content with padding to avoid logo overlap -->
      <div class="pl-28 pt-4">
        <div class="text-left">
          <div class="font-bold text-2xl mb-2 bg-gradient-to-r from-white to-neutral-300 bg-clip-text text-transparent">
            ByteFlipper
          </div>
          <div class="text-transparent bg-gradient-to-r from-pink-500 to-orange-500 bg-clip-text font-medium mb-4">
            Lead Developer & Project Creator
          </div>
          <div class="flex flex-wrap gap-3">
            <a href="https://byteflipper.com" 
               class="px-4 py-2 rounded-lg border border-neutral-800 hover:bg-gradient-to-r hover:from-pink-600/20 hover:to-orange-600/20 hover:border-neutral-600 transition-all duration-300 hover:shadow-lg">
              byteflipper.com
            </a>
            <a href="https://github.com/byteflipper-58" 
               class="px-4 py-2 rounded-lg border border-neutral-800 hover:bg-gradient-to-r hover:from-pink-600/20 hover:to-orange-600/20 hover:border-neutral-600 transition-all duration-300 hover:shadow-lg">
              GitHub Profile
            </a>
            <a href="https://github.com/byteflipper-58/sectlauncher" 
               class="px-4 py-2 rounded-lg border border-neutral-800 hover:bg-gradient-to-r hover:from-pink-600/20 hover:to-orange-600/20 hover:border-neutral-600 transition-all duration-300 hover:shadow-lg">
              SectLauncher Repository
            </a>
            <a href="https://t.me/byteflipper" 
               class="px-4 py-2 rounded-lg border border-blue-600/50 bg-blue-600/10 hover:bg-blue-600/20 hover:border-blue-500 transition-all duration-300 hover:shadow-lg text-blue-300 hover:text-blue-200">
              Telegram Channel
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

  <Fragment slot="footer"><Footer /></Fragment>
</BaseLayout>

