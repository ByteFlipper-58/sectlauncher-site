---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
---

<BaseLayout title="SectLauncher — Minecraft launcher" description="Mods, profiles, auto‑updates in one click.">
  <Fragment slot="header"><Header /></Fragment>
  <Fragment slot="head">
    <link rel="canonical" href="https://sectlauncher.byteflipper.com/en/" />
    <link rel="alternate" hreflang="ru" href="https://sectlauncher.byteflipper.com/ru/" />
    <link rel="alternate" hreflang="x-default" href="https://sectlauncher.byteflipper.com/ru/" />
    <meta property="og:url" content="https://sectlauncher.byteflipper.com/en/" />
    <link rel="preload" as="image" href="/blog/sectlauncher-2-0/launcher_home.png" />
  </Fragment>

  <section class="hero-bg">
    <div class="mx-auto max-w-6xl px-4 pt-16 pb-14 grid md:grid-cols-2 gap-10 items-center">
      <div>
        <h1 class="text-4xl md:text-5xl font-extrabold leading-tight">SectLauncher — modern Minecraft launcher</h1>
        <p class="mt-4 text-neutral-300 text-lg">Manage mods, create profiles and update games with one button. Just launch — we handle the rest.</p>
        <div class="mt-4 inline-flex items-center px-3 py-2 rounded-lg bg-orange-500/20 border border-orange-500/30">
          <svg class="w-4 h-4 mr-2 text-orange-400" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/>
          </svg>
          <span class="text-orange-300 font-medium text-sm">Project in active development</span>
        </div>
        <div class="mt-6 flex flex-wrap items-center gap-3">
          <div class="px-5 py-3 rounded-md font-semibold text-orange-900 bg-orange-500 cursor-not-allowed opacity-75">
            In Development
          </div>
          <a href="https://github.com/byteflipper-58/sectlauncher" class="px-5 py-3 rounded-md border border-neutral-700 hover:bg-neutral-800">GitHub</a>
          <a href="https://t.me/sectlauncher" class="px-5 py-3 rounded-md border border-neutral-700 hover:bg-neutral-800">Telegram</a>
        </div>
        <div class="mt-3 text-xs text-neutral-400">Coming soon for download</div>
      </div>
      <div class="relative">
        <img
          src="/blog/sectlauncher-2-0/launcher_home.png"
          alt="SectLauncher Interface"
          width="1024"
          height="640"
          fetchpriority="high"
          decoding="async"
          class="w-full h-auto object-contain transition-transform duration-500 hover:scale-[1.02]"
        />
      </div>
    </div>
  </section>

  <div aria-hidden="true" class="relative">
    <div class="mx-auto max-w-6xl px-4">
      <div class="h-px bg-gradient-to-r from-transparent via-neutral-800 to-transparent"></div>
    </div>
  </div>

  <!-- New feature showcase section -->
  <section class="mx-auto max-w-6xl px-4 py-24 space-y-32">
    <!-- Block 1: Native & Performance -->
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <div class="order-2 md:order-1">
        <img
          src="/blog/sectlauncher-2-0/launcher_home.png"
          alt="SectLauncher Home Screen"
          width="800"
          height="500"
          class="w-full h-auto object-contain transition-transform duration-500 hover:scale-[1.02]"
        />
      </div>
      <div class="order-1 md:order-2 space-y-6">
        <h2 class="text-3xl md:text-4xl font-black uppercase tracking-tight text-white leading-none">
          Native <span class="text-orange-500">Rust</span> Power
        </h2>
        <p class="text-neutral-400 text-lg leading-relaxed">
          SectLauncher is rebuilt in Rust using Tauri v2. This provides lightning-fast startup, minimal resource consumption, and native performance on Windows, Mac, and Linux. No extra weight — just pure power.
        </p>
        <ul class="space-y-3 text-neutral-300">
          <li class="flex items-center gap-3">
            <div class="w-1.5 h-1.5 bg-orange-500"></div>
            Instant UI response
          </li>
          <li class="flex items-center gap-3">
            <div class="w-1.5 h-1.5 bg-orange-500"></div>
            Minimal application footprint
          </li>
          <li class="flex items-center gap-3">
            <div class="w-1.5 h-1.5 bg-orange-500"></div>
            Secure native code
          </li>
        </ul>
      </div>
    </div>

    <!-- Block 2: Mods & Instances -->
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <div class="space-y-6">
        <h2 class="text-3xl md:text-4xl font-black uppercase tracking-tight text-white leading-none">
          One-click <span class="text-blue-500">Forge & Fabric</span>
        </h2>
        <p class="text-neutral-400 text-lg leading-relaxed">
          No more struggling with manual loader installations. SectLauncher automatically downloads and configures the necessary game and mod versions, creating isolated instances.
        </p>
        <ul class="space-y-3 text-neutral-300">
          <li class="flex items-center gap-3">
            <div class="w-1.5 h-1.5 bg-blue-500"></div>
            Automatic Forge/Fabric installation
          </li>
          <li class="flex items-center gap-3">
            <div class="w-1.5 h-1.5 bg-blue-500"></div>
            Smart game world isolation
          </li>
          <li class="flex items-center gap-3">
            <div class="w-1.5 h-1.5 bg-blue-500"></div>
            Official Microsoft authentication
          </li>
        </ul>
      </div>
      <div>
        <img
          src="/blog/sectlauncher-2-0/launcher_instances.png"
          alt="Instance management"
          width="800"
          height="500"
          class="w-full h-auto object-contain transition-transform duration-500 hover:scale-[1.02]"
        />
      </div>
    </div>

    <!-- Block 3: Personalization -->
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <div class="order-2 md:order-1">
        <img
          src="/blog/sectlauncher-2-0/launcher_personalization.png"
          alt="Personalization settings"
          width="800"
          height="500"
          class="w-full h-auto object-contain transition-transform duration-500 hover:scale-[1.02]"
        />
      </div>
      <div class="order-1 md:order-2 space-y-6">
        <h2 class="text-3xl md:text-4xl font-black uppercase tracking-tight text-white leading-none">
          Your Launcher — <span class="text-purple-500">Your Rules</span>
        </h2>
        <p class="text-neutral-400 text-lg leading-relaxed">
          Personalization is not just about changing colors. Customize accent colors to match your mood or upload any image for the home screen background. Make SectLauncher truly yours.
        </p>
        <ul class="space-y-3 text-neutral-300">
          <li class="flex items-center gap-3">
            <div class="w-1.5 h-1.5 bg-purple-500"></div>
            Flexible UI theme system
          </li>
          <li class="flex items-center gap-3">
            <div class="w-1.5 h-1.5 bg-purple-500"></div>
            Custom background images
          </li>
          <li class="flex items-center gap-3">
            <div class="w-1.5 h-1.5 bg-purple-500"></div>
            Minimalist professional look
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Roadmap -->
  <section class="mx-auto max-w-6xl px-4 py-16">
    <div class="mb-12 border-l-4 border-blue-600 pl-5">
      <h2 class="text-4xl font-black tracking-tight uppercase text-white mb-1">Roadmap</h2>
      <p class="text-neutral-500 font-medium uppercase tracking-widest text-xs">Technical project development path</p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-12">
      <!-- Left Column: Implemented -->
      <div>
        <div class="flex items-center gap-3 mb-8">
          <h3 class="text-xl font-bold text-emerald-500 uppercase tracking-tight">Implemented</h3>
          <div class="flex-grow h-px bg-emerald-500/10"></div>
        </div>
        
        <ul class="space-y-5">
          {[
            { title: "Rust & Tauri v2 Core", desc: "Maximum performance and security of native code." },
            { title: "Win / Mac / Linux Support", desc: "Unified interface and functionality across all popular OS." },
            { title: "OTA Update System", desc: "Automatic patches without reinstallation." },
            { title: "Microsoft Auth", desc: "Secure login through official Microsoft services." },
            { title: "Fabric / Forge Support", desc: "Native support for the most popular mod loaders." },
            { title: "JVM & UI Themes", desc: "Flexible parameter adjustment and UI customization." }
          ].map((item) => (
            <li class="group">
              <div class="flex items-start gap-3">
                <div class="mt-1.5 w-1.5 h-1.5 bg-emerald-500 flex-shrink-0"></div>
                <div>
                  <h4 class="text-base font-bold text-neutral-100 group-hover:text-emerald-400 transition-colors uppercase tracking-tight leading-tight">{item.title}</h4>
                  <p class="text-neutral-500 text-xs leading-relaxed mt-0.5">{item.desc}</p>
                </div>
              </div>
            </li>
          ))}
        </ul>
      </div>

      <!-- Right Column: Planned -->
      <div>
        <div class="flex items-center gap-3 mb-8">
          <h3 class="text-xl font-bold text-blue-500 uppercase tracking-tight">Planned</h3>
          <div class="flex-grow h-px bg-blue-500/10"></div>
        </div>

        <ul class="space-y-5">
          {[
            { title: "CurseForge / Modrinth", desc: "Direct integration with the largest mod databases." },
            { title: "Auto-update Modpacks", desc: "Automatic synchronization of mod versions in your builds." },
            { title: "Instance Isolation", desc: "Enhanced sandbox for separating game profiles." },
            { title: "Resource Manager", desc: "Advanced memory and game asset management." }
          ].map((item) => (
            <li class="group">
              <div class="flex items-start gap-3 text-neutral-400">
                <div class="mt-1.5 w-1.5 h-1.5 border border-blue-500 flex-shrink-0"></div>
                <div>
                  <h4 class="text-base font-bold text-neutral-300 group-hover:text-blue-400 transition-colors uppercase tracking-tight leading-tight">{item.title}</h4>
                  <p class="text-neutral-500 text-xs leading-relaxed mt-0.5">{item.desc}</p>
                </div>
              </div>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

        </div>
      </div>
    </div>
  </section>

  <Fragment slot="footer"><Footer /></Fragment>
</BaseLayout>

