---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
---

<BaseLayout title="О проекте — SectLauncher" description="SectLauncher — современный лаунчер для Minecraft на Rust + Tauri v2 с Clean Architecture.">
  <Fragment slot="header"><Header /></Fragment>
  <Fragment slot="head">
    <link rel="canonical" href="https://sectlauncher.byteflipper.com/ru/about/" />
    <link rel="alternate" hreflang="en" href="https://sectlauncher.byteflipper.com/en/about/" />
    <link rel="alternate" hreflang="x-default" href="https://sectlauncher.byteflipper.com/ru/about/" />
    <meta property="og:url" content="https://sectlauncher.byteflipper.com/ru/about/" />
  </Fragment>

  <!-- Hero секция -->
  <section class="hero-bg">
    <div class="mx-auto max-w-6xl px-4 py-16">
      <div class="text-center max-w-4xl mx-auto">
        <h1 class="text-4xl md:text-5xl font-extrabold mb-6">
          SectLauncher
          <span class="block text-2xl md:text-3xl text-emerald-400 mt-2">Инженерный подход к лаунчерам</span>
        </h1>
        <p class="text-xl text-neutral-300 mb-6 leading-relaxed">
          Современный лаунчер для Minecraft на Rust + Tauri v2, построенный по принципам Clean Architecture. Цель — удобная, производительная и безопасная оболочка для игры с поддержкой ванильных и модифицированных клиентов.
        </p>
        
        <div class="inline-flex items-center px-4 py-3 rounded-lg bg-emerald-500/10 border border-emerald-500/20 mb-8">
          <span class="text-emerald-400 font-medium text-sm flex items-center gap-2">
            <div class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></div>
            Доступна новая версия
          </span>
        </div>
        <div class="flex flex-wrap justify-center gap-4">
          <a href="/ru/download" class="px-6 py-3 rounded-lg font-semibold text-emerald-900 bg-emerald-500 hover:bg-emerald-400 transition-colors shadow-sm inline-flex items-center gap-2">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z"/></svg>
            Скачать лаунчер
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Статус разработки -->
  <section class="mx-auto max-w-6xl px-4 py-16">
    <div class="grid lg:grid-cols-2 gap-12">
      <!-- Что готово -->
      <div>
        <h2 class="text-3xl font-bold mb-6 text-emerald-400">✅ Реализовано</h2>
        <div class="space-y-4">
          <div class="flex items-start gap-3 p-4 rounded-lg bg-emerald-500/10 border border-emerald-500/20">
            <div class="w-2 h-2 rounded-full bg-emerald-500 mt-2 shrink-0"></div>
            <div>
              <h3 class="font-semibold">Авторизация Microsoft/Mojang</h3>
              <p class="text-neutral-300 text-sm">Полноценная система аутентификации через официальные API</p>
            </div>
          </div>

          <div class="flex items-start gap-3 p-4 rounded-lg bg-emerald-500/10 border border-emerald-500/20">
            <div class="w-2 h-2 rounded-full bg-emerald-500 mt-2 shrink-0"></div>
            <div>
              <h3 class="font-semibold">Загрузка Minecraft</h3>
              <p class="text-neutral-300 text-sm">Автоматическое скачивание и установка Vanilla, Fabric и Forge версий</p>
            </div>
          </div>

          <div class="flex items-start gap-3 p-4 rounded-lg bg-emerald-500/10 border border-emerald-500/20">
            <div class="w-2 h-2 rounded-full bg-emerald-500 mt-2 shrink-0"></div>
            <div>
              <h3 class="font-semibold">OTA-Обновления</h3>
              <p class="text-neutral-300 text-sm">Автоматическое обновление лаунчера без участия пользователя</p>
            </div>
          </div>

          <div class="flex items-start gap-3 p-4 rounded-lg bg-emerald-500/10 border border-emerald-500/20">
            <div class="w-2 h-2 rounded-full bg-emerald-500 mt-2 shrink-0"></div>
            <div>
              <h3 class="font-semibold">Кроссплатформенность</h3>
              <p class="text-neutral-300 text-sm">Полная поддержка Windows 10/11, macOS и Linux</p>
            </div>
          </div>
        </div>
      </div>

      <!-- В процессе и планы -->
      <div class="space-y-12">
        <div>
          <h2 class="text-3xl font-bold mb-6 text-blue-400">🚧 В процессе</h2>
          <div class="space-y-4">
            <div class="flex items-start gap-3 p-4 rounded-lg bg-blue-500/10 border border-blue-500/20">
              <div class="w-2 h-2 rounded-full bg-blue-500 mt-2 shrink-0"></div>
              <div>
                <h3 class="font-semibold">Интеграция Modrinth и CurseForge</h3>
                <p class="text-neutral-300 text-sm">Удобный поиск и автоматическая установка модов из популярных сервисов</p>
              </div>
            </div>
            
            <div class="flex items-start gap-3 p-4 rounded-lg bg-blue-500/10 border border-blue-500/20">
              <div class="w-2 h-2 rounded-full bg-blue-500 mt-2 shrink-0"></div>
              <div>
                <h3 class="font-semibold">Полировка UI/UX</h3>
                <p class="text-neutral-300 text-sm">Доведение интерфейса до идеала перед публичным релизом</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-16">
    <div class="w-full max-w-none">
      <div class="rounded-2xl border border-neutral-800 bg-neutral-900/50 p-8 hover:border-neutral-700 transition-all duration-300 relative">
        <!-- Логотип в верхнем левом углу -->
        <div class="absolute top-6 left-6 w-20 h-20 rounded-xl overflow-hidden z-10">
          <img 
            src="https://byteflipper.web.app/images/logo.png" 
            alt="Логотип ByteFlipper" 
            class="w-full h-full object-cover rounded-xl shadow-lg hover:scale-105 transition-transform duration-300"
            onerror="this.style.display='none'; this.nextElementSibling.style.display='flex'"
          />
          <!-- Запасной вариант, если изображение не загрузится -->
          <div class="absolute inset-0 w-20 h-20 rounded-xl grid place-items-center text-2xl font-bold text-neutral-900" style="background:linear-gradient(135deg,#ef116f,#fe6407); display: none;">
            BF
          </div>
        </div>
        
        <!-- Основной контент с отступом, чтобы не перекрывать логотип -->
        <div class="pl-28 pt-4">
          <div class="text-left">
            <div class="font-bold text-2xl mb-2 bg-gradient-to-r from-white to-neutral-300 bg-clip-text text-transparent">
              ByteFlipper
            </div>
            <div class="text-transparent bg-gradient-to-r from-pink-500 to-orange-500 bg-clip-text font-medium mb-4">
              Ведущий разработчик и создатель проекта
            </div>
            <div class="flex flex-wrap gap-3">
              <a href="https://byteflipper.com" 
                 class="px-4 py-2 rounded-lg border border-neutral-800 hover:bg-gradient-to-r hover:from-pink-600/20 hover:to-orange-600/20 hover:border-neutral-600 transition-all duration-300 hover:shadow-lg">
                byteflipper.com
              </a>
              <a href="https://github.com/byteflipper-58" 
                 class="px-4 py-2 rounded-lg border border-neutral-800 hover:bg-gradient-to-r hover:from-pink-600/20 hover:to-orange-600/20 hover:border-neutral-600 transition-all duration-300 hover:shadow-lg">
                Профиль GitHub
              </a>
              <a href="https://github.com/byteflipper-58/sectlauncher" 
                 class="px-4 py-2 rounded-lg border border-neutral-800 hover:bg-gradient-to-r hover:from-pink-600/20 hover:to-orange-600/20 hover:border-neutral-600 transition-all duration-300 hover:shadow-lg">
                Репозиторий SectLauncher
              </a>
              <a href="https://t.me/byteflipper" 
                 class="px-4 py-2 rounded-lg border border-blue-600/50 bg-blue-600/10 hover:bg-blue-600/20 hover:border-blue-500 transition-all duration-300 hover:shadow-lg text-blue-300 hover:text-blue-200">
                Telegram канал
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Fragment slot="footer"><Footer /></Fragment>
</BaseLayout>

