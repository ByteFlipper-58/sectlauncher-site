---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { RELEASES_FALLBACK_URL } from "../../utils/site";

const FALLBACK_URL = RELEASES_FALLBACK_URL;

const winUrl = FALLBACK_URL;
const macSiliconUrl = FALLBACK_URL;
const macIntelUrl = FALLBACK_URL;
const macTarUrl = FALLBACK_URL;
const appImgUrl = FALLBACK_URL;
const debUrl = FALLBACK_URL;
const rpmUrl = FALLBACK_URL;
---

<BaseLayout title="Скачать — SectLauncher" description="Скачайте SectLauncher для Windows, macOS и Linux.">
  <Fragment slot="header"><Header /></Fragment>
  <Fragment slot="head">
    <link rel="canonical" href="https://sectlauncher.byteflipper.com/ru/download/" />
    <link rel="alternate" hreflang="en" href="https://sectlauncher.byteflipper.com/en/download/" />
    <link rel="alternate" hreflang="x-default" href="https://sectlauncher.byteflipper.com/ru/download/" />
    <meta property="og:url" content="https://sectlauncher.byteflipper.com/ru/download/" />
  </Fragment>

  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-emerald-500/5 via-transparent to-transparent pointer-events-none"></div>
    <div class="mx-auto max-w-5xl px-4 pt-20 pb-12 text-center relative">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-emerald-500/10 border border-emerald-500/20 mb-6">
        <div class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></div>
        <span class="text-emerald-400 text-xs font-semibold uppercase tracking-widest" id="version-display" data-version-fallback-label="Последняя">Загрузка...</span>
      </div>
      <h1 class="text-4xl md:text-5xl font-extrabold leading-tight mb-4">Скачать <span class="text-emerald-500">SectLauncher</span></h1>
      <p class="text-neutral-400 text-lg max-w-xl mx-auto">Выбери сборку для своей ОС и начни играть за пару минут.</p>
    </div>
  </section>

  <!-- OS Cards -->
  <section class="mx-auto max-w-5xl px-4 pb-24">
    <div class="grid md:grid-cols-3 gap-5" id="os-cards">

      <!-- Windows -->
      <div class="relative group">
        <div class="absolute -inset-px rounded-2xl bg-gradient-to-b from-blue-500/30 to-blue-500/0 opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>
        <div class="relative bg-neutral-900/80 backdrop-blur border border-neutral-800 rounded-2xl p-7 flex flex-col items-center text-center h-full group-hover:border-blue-500/30 transition-colors duration-500">
          <div class="w-16 h-16 rounded-xl bg-blue-500/10 border border-blue-500/20 flex items-center justify-center mb-6 group-hover:bg-blue-500/20 transition-colors">
            <img src="/windows-11.svg" alt="Windows" class="w-8 h-8 object-contain brightness-0 invert opacity-80 group-hover:opacity-100 transition-opacity" />
          </div>
          <h2 class="text-lg font-bold uppercase tracking-wider mb-1">Windows</h2>
          <p class="text-neutral-500 text-[11px] uppercase tracking-widest mb-8 flex-grow">Windows 10 / 11 · 64-bit</p>

          <div class="w-full">
            <a href={winUrl} id="btn-win" data-download-platform="windows" class="w-full py-3 rounded-lg font-bold uppercase tracking-widest text-[11px] bg-blue-600 hover:bg-blue-500 text-white transition-colors flex items-center justify-center gap-2">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z"/></svg>
              Скачать .exe
            </a>
          </div>
        </div>
      </div>

      <!-- macOS -->
      <div class="relative group">
        <div class="absolute -inset-px rounded-2xl bg-gradient-to-b from-neutral-400/20 to-neutral-400/0 opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>
        <div class="relative bg-neutral-900/80 backdrop-blur border border-neutral-800 rounded-2xl p-7 flex flex-col items-center text-center h-full group-hover:border-neutral-600/50 transition-colors duration-500">
          <div class="w-16 h-16 rounded-xl bg-neutral-800/80 border border-neutral-700/50 flex items-center justify-center mb-6 group-hover:bg-neutral-700/50 transition-colors">
            <svg class="w-8 h-8 text-white opacity-80 group-hover:opacity-100 transition-opacity" fill="currentColor" viewBox="0 0 24 24">
              <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.81-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
            </svg>
          </div>
          <h2 class="text-lg font-bold uppercase tracking-wider mb-1">macOS</h2>
          <p class="text-neutral-500 text-[11px] uppercase tracking-widest mb-8 flex-grow">Apple Silicon & Intel</p>

          <div class="w-full space-y-2">
            <a href={macSiliconUrl} id="btn-mac" data-download-platform="mac" class="w-full py-3 rounded-lg font-bold uppercase tracking-widest text-[11px] bg-neutral-100 hover:bg-white text-neutral-900 transition-colors flex items-center justify-center gap-2">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z"/></svg>
              Apple Silicon
            </a>
            <div class="relative">
              <button type="button" class="w-full py-2.5 rounded-lg text-[10px] font-semibold uppercase tracking-widest text-neutral-400 border border-neutral-800 hover:border-neutral-700 hover:text-neutral-200 transition-colors flex items-center justify-center gap-1" data-dropdown-btn="mac">
                Другие форматы
                <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M7 10l5 5 5-5z"/></svg>
              </button>
              <div class="absolute top-full left-0 right-0 mt-1 bg-neutral-950 border border-neutral-800 rounded-lg shadow-2xl z-20 hidden overflow-hidden" data-dropdown-menu="mac">
                <a href={macIntelUrl} id="btn-mac-intel" data-download-platform="mac" class="block w-full px-5 py-3 text-[10px] font-semibold uppercase tracking-widest text-neutral-400 hover:bg-neutral-900 hover:text-white transition-colors border-b border-neutral-800/50">Intel (.app.tar.gz)</a>
                <a href={macTarUrl} id="btn-mac-tar" data-download-platform="mac" class="block w-full px-5 py-3 text-[10px] font-semibold uppercase tracking-widest text-neutral-400 hover:bg-neutral-900 hover:text-white transition-colors">Универсальный (.tar.gz)</a>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Linux -->
      <div class="relative group">
        <div class="absolute -inset-px rounded-2xl bg-gradient-to-b from-orange-500/30 to-orange-500/0 opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>
        <div class="relative bg-neutral-900/80 backdrop-blur border border-neutral-800 rounded-2xl p-7 flex flex-col items-center text-center h-full group-hover:border-orange-500/30 transition-colors duration-500">
          <div class="w-16 h-16 rounded-xl bg-orange-500/10 border border-orange-500/20 flex items-center justify-center mb-6 group-hover:bg-orange-500/20 transition-colors">
            <img src="/os-linux.svg" alt="Linux" class="w-8 h-8 object-contain brightness-0 invert opacity-80 group-hover:opacity-100 transition-opacity" />
          </div>
          <h2 class="text-lg font-bold uppercase tracking-wider mb-1">Linux</h2>
          <p class="text-neutral-500 text-[11px] uppercase tracking-widest mb-8 flex-grow">AppImage · .deb · .rpm</p>

          <div class="w-full space-y-2">
            <a href={appImgUrl} id="btn-linux-appimage" data-download-platform="linux" class="w-full py-3 rounded-lg font-bold uppercase tracking-widest text-[11px] bg-orange-600 hover:bg-orange-500 text-white transition-colors flex items-center justify-center gap-2">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z"/></svg>
              AppImage
            </a>
            <div class="relative">
              <button type="button" class="w-full py-2.5 rounded-lg text-[10px] font-semibold uppercase tracking-widest text-neutral-400 border border-neutral-800 hover:border-neutral-700 hover:text-neutral-200 transition-colors flex items-center justify-center gap-1" data-dropdown-btn="linux">
                Другие форматы
                <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M7 10l5 5 5-5z"/></svg>
              </button>
              <div class="absolute top-full left-0 right-0 mt-1 bg-neutral-950 border border-neutral-800 rounded-lg shadow-2xl z-20 hidden overflow-hidden" data-dropdown-menu="linux">
                <a href={debUrl} id="btn-linux-deb" data-download-platform="linux" class="block w-full px-5 py-3 text-[10px] font-semibold uppercase tracking-widest text-neutral-400 hover:bg-neutral-900 hover:text-white transition-colors border-b border-neutral-800/50">Debian / Ubuntu (.deb)</a>
                <a href={rpmUrl} id="btn-linux-rpm" data-download-platform="linux" class="block w-full px-5 py-3 text-[10px] font-semibold uppercase tracking-widest text-neutral-400 hover:bg-neutral-900 hover:text-white transition-colors">Fedora / RHEL (.rpm)</a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Fragment slot="footer"><Footer /></Fragment>
</BaseLayout>

<script type="module">
  import { initDownloadPage } from "../../scripts/download-page";

  initDownloadPage();
</script>
