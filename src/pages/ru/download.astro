---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import latest from "../../../public/latest.json";

const isDev = import.meta.env.DEV;
const { version, platforms } = latest;
const FALLBACK_URL = 'https://github.com/ByteFlipper-58/sectlauncher/releases/latest';

const winUrl = platforms['windows-x86_64']?.url || FALLBACK_URL;
const winNsisUrl = platforms['windows-x86_64-nsis']?.url || FALLBACK_URL;
const macSiliconUrl = platforms['darwin-aarch64-app']?.url || platforms['darwin-aarch64']?.url || FALLBACK_URL;
const macIntelUrl = platforms['darwin-x86_64-app']?.url || platforms['darwin-x86_64']?.url || FALLBACK_URL;
const macTarUrl = platforms['darwin-aarch64']?.url || FALLBACK_URL;
const appImgUrl = platforms['linux-x86_64-appimage']?.url || platforms['linux-x86_64']?.url || FALLBACK_URL;
const debUrl = platforms['linux-x86_64-deb']?.url || FALLBACK_URL;
const rpmUrl = platforms['linux-x86_64-rpm']?.url || FALLBACK_URL;
---

<BaseLayout title="Скачать — SectLauncher" description="Скачайте SectLauncher для Windows, macOS и Linux.">
  <Fragment slot="header"><Header /></Fragment>
  <Fragment slot="head">
    <link rel="canonical" href="https://sectlauncher.byteflipper.com/ru/download/" />
    <link rel="alternate" hreflang="en" href="https://sectlauncher.byteflipper.com/en/download/" />
    <link rel="alternate" hreflang="x-default" href="https://sectlauncher.byteflipper.com/ru/download/" />
    <meta property="og:url" content="https://sectlauncher.byteflipper.com/ru/download/" />
  </Fragment>

  <section class="hero-bg min-h-[80vh] flex flex-col items-center justify-center">
    <div class="mx-auto w-full max-w-6xl px-4 py-16">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <h1 class="text-4xl md:text-5xl font-extrabold mb-6">Скачать SectLauncher</h1>
        <p class="text-xl text-neutral-300 mb-4 leading-relaxed">
          Современный лаунчер для Minecraft. Установите версию для вашей операционной системы.
        </p>
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-neutral-900 border border-neutral-800">
          <div class="w-2 h-2 rounded-full bg-emerald-500"></div>
          <span class="text-neutral-300 text-sm font-medium" id="version-display">Версия: {version}</span>
        </div>
      </div>

      <div class="grid md:grid-cols-3 gap-6 max-w-5xl mx-auto" id="os-cards">
        <!-- Windows -->
        <div class="bg-neutral-900 border border-neutral-800 p-8 flex flex-col items-center text-center transition-all hover:bg-neutral-800/50 group rounded-none">
          <div class="w-20 h-20 bg-neutral-950 border border-neutral-800 flex items-center justify-center mb-8 p-4 rounded-none group-hover:border-blue-500/50 transition-colors">
            <img src="/windows-11.svg" alt="Windows" class="w-full h-full object-contain brightness-0 invert opacity-70 group-hover:opacity-100 transition-opacity" />
          </div>
          <h2 class="text-xl font-bold uppercase tracking-widest mb-2">Windows</h2>
          <p class="text-neutral-500 text-xs uppercase tracking-wider mb-10 flex-grow">Windows 10 / 11 (64-bit)</p>
          
          <div class="relative w-full flex isolate">
            <a href={winUrl} id="btn-win" class="flex-grow py-4 px-6 font-bold uppercase tracking-[0.2em] text-[10px] text-neutral-950 bg-white hover:bg-neutral-200 transition-colors flex items-center justify-center gap-2 rounded-none">
              <span>Скачать .exe</span>
            </a>
            <button type="button" class="px-4 border-l border-neutral-200 bg-white hover:bg-neutral-200 text-neutral-950 transition-colors rounded-none" data-dropdown-btn="windows">
              <svg class="w-4 h-4 pointer-events-none" fill="currentColor" viewBox="0 0 24 24"><path d="M7 10l5 5 5-5z"/></svg>
            </button>
            <div class="absolute top-full right-0 mt-1 w-full bg-neutral-950 border border-neutral-800 shadow-2xl z-20 hidden text-left rounded-none" data-dropdown-menu="windows">
              <a href={winNsisUrl} id="btn-win-nsis" class="block w-full px-6 py-4 text-[10px] font-bold uppercase tracking-widest text-neutral-400 hover:bg-neutral-900 hover:text-white transition-colors border-b border-neutral-800/50">Setup (.exe NSIS)</a>
            </div>
          </div>
        </div>

        <!-- macOS -->
        <div class="bg-neutral-900 border border-neutral-800 p-8 flex flex-col items-center text-center transition-all hover:bg-neutral-800/50 group rounded-none">
          <div class="w-20 h-20 bg-neutral-950 border border-neutral-800 flex items-center justify-center mb-8 p-4 rounded-none group-hover:border-neutral-500/50 transition-colors">
            <svg class="w-full h-full text-white opacity-70 group-hover:opacity-100 transition-opacity" fill="currentColor" viewBox="0 0 24 24">
              <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.81-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
            </svg>
          </div>
          <h2 class="text-xl font-bold uppercase tracking-widest mb-2">macOS</h2>
          <p class="text-neutral-500 text-xs uppercase tracking-wider mb-10 flex-grow">Apple Silicon & Intel</p>
          
          <div class="relative w-full flex isolate">
            <a href={macSiliconUrl} id="btn-mac" class="flex-grow py-4 px-6 font-bold uppercase tracking-[0.2em] text-[10px] text-neutral-950 bg-white hover:bg-neutral-200 transition-colors flex items-center justify-center gap-2 rounded-none">
              <span>Apple Silicon (.app)</span>
            </a>
            <button type="button" class="px-4 border-l border-neutral-200 bg-white hover:bg-neutral-200 text-neutral-950 transition-colors rounded-none" data-dropdown-btn="mac">
              <svg class="w-4 h-4 pointer-events-none" fill="currentColor" viewBox="0 0 24 24"><path d="M7 10l5 5 5-5z"/></svg>
            </button>
            <div class="absolute top-full right-0 mt-1 w-full bg-neutral-950 border border-neutral-800 shadow-2xl z-20 hidden text-left rounded-none" data-dropdown-menu="mac">
              <a href={macIntelUrl} id="btn-mac-intel" class="block w-full px-6 py-4 text-[10px] font-bold uppercase tracking-widest text-neutral-400 hover:bg-neutral-900 hover:text-white transition-colors border-b border-neutral-800/50">Intel (.app.tar.gz)</a>
              <a href={macTarUrl} id="btn-mac-tar" class="block w-full px-6 py-4 text-[10px] font-bold uppercase tracking-widest text-neutral-400 hover:bg-neutral-900 hover:text-white transition-colors">Универсальный (.tar.gz)</a>
            </div>
          </div>
        </div>

        <!-- Linux -->
        <div class="bg-neutral-900 border border-neutral-800 p-8 flex flex-col items-center text-center transition-all hover:bg-neutral-800/50 group rounded-none">
          <div class="w-20 h-20 bg-neutral-950 border border-neutral-800 flex items-center justify-center mb-8 p-4 rounded-none group-hover:border-orange-500/50 transition-colors">
            <img src="/os-linux.svg" alt="Linux" class="w-full h-full object-contain brightness-0 invert opacity-70 group-hover:opacity-100 transition-opacity" />
          </div>
          <h2 class="text-xl font-bold uppercase tracking-widest mb-2">Linux</h2>
          <p class="text-neutral-500 text-xs uppercase tracking-wider mb-10 flex-grow">AppImage / .deb / .rpm</p>
          
          <div class="relative w-full flex isolate">
            <a href={appImgUrl} id="btn-linux-appimage" class="flex-grow py-4 px-6 font-bold uppercase tracking-[0.2em] text-[10px] text-neutral-950 bg-white hover:bg-neutral-200 transition-colors flex items-center justify-center gap-2 rounded-none">
              <span>AppImage</span>
            </a>
            <button type="button" class="px-4 border-l border-neutral-200 bg-white hover:bg-neutral-200 text-neutral-950 transition-colors rounded-none" data-dropdown-btn="linux">
              <svg class="w-4 h-4 pointer-events-none" fill="currentColor" viewBox="0 0 24 24"><path d="M7 10l5 5 5-5z"/></svg>
            </button>
            <div class="absolute top-full right-0 mt-1 w-full bg-neutral-950 border border-neutral-800 shadow-2xl z-20 hidden text-left rounded-none" data-dropdown-menu="linux">
              <a href={debUrl} id="btn-linux-deb" class="block w-full px-6 py-4 text-[10px] font-bold uppercase tracking-widest text-neutral-400 hover:bg-neutral-900 hover:text-white transition-colors border-b border-neutral-800/50">Debian / Ubuntu (.deb)</a>
              <a href={rpmUrl} id="btn-linux-rpm" class="block w-full px-6 py-4 text-[10px] font-bold uppercase tracking-widest text-neutral-400 hover:bg-neutral-900 hover:text-white transition-colors">Fedora / RHEL (.rpm)</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Fragment slot="footer"><Footer /></Fragment>
</BaseLayout>

<script define:vars={{ isDev }}>
  const JSON_URL = isDev 
    ? '/latest.json' 
    : 'https://github.com/ByteFlipper-58/sectlauncher/releases/latest/download/latest.json';

  const FALLBACK_URL = 'https://github.com/ByteFlipper-58/sectlauncher/releases/latest';

  const versionEl = document.getElementById('version-display');
  const btnWin = document.getElementById('btn-win');
  const btnWinNsis = document.getElementById('btn-win-nsis');
  const btnMac = document.getElementById('btn-mac');
  const btnMacIntel = document.getElementById('btn-mac-intel');
  const btnMacTar = document.getElementById('btn-mac-tar');
  const btnLinAppImg = document.getElementById('btn-linux-appimage');
  const btnLinDeb = document.getElementById('btn-linux-deb');
  const btnLinRpm = document.getElementById('btn-linux-rpm');

  function enableBtn(btn, url) {
    if (!btn) return;
    btn.href = url;
    btn.classList.remove('opacity-50', 'cursor-not-allowed');
  }

  async function fetchVersion() {
    try {
      const res = await fetch(JSON_URL);
      if (!res.ok) throw new Error('Failed to fetch');
      const data = await res.json();
      
      versionEl.textContent = `Актуальная версия: ${data.version}`;

      // Win
      const winUrl = data.platforms?.['windows-x86_64']?.url || FALLBACK_URL;
      const winNsisUrl = data.platforms?.['windows-x86_64-nsis']?.url || FALLBACK_URL;
      enableBtn(btnWin, winUrl);
      enableBtn(btnWinNsis, winNsisUrl);
      
      // Mac
      const macSiliconUrl = data.platforms?.['darwin-aarch64-app']?.url || data.platforms?.['darwin-aarch64']?.url || FALLBACK_URL;
      const macIntelUrl = data.platforms?.['darwin-x86_64-app']?.url || data.platforms?.['darwin-x86_64']?.url || FALLBACK_URL;
      const macTarUrl = data.platforms?.['darwin-aarch64']?.url || FALLBACK_URL;

      enableBtn(btnMac, macSiliconUrl);
      enableBtn(btnMacIntel, macIntelUrl);
      enableBtn(btnMacTar, macTarUrl);

      // Linux
      const appImgUrl = data.platforms?.['linux-x86_64-appimage']?.url || data.platforms?.['linux-x86_64']?.url || FALLBACK_URL;
      const debUrl = data.platforms?.['linux-x86_64-deb']?.url || FALLBACK_URL;
      const rpmUrl = data.platforms?.['linux-x86_64-rpm']?.url || FALLBACK_URL;
      
      enableBtn(btnLinAppImg, appImgUrl);
      enableBtn(btnLinDeb, debUrl);
      enableBtn(btnLinRpm, rpmUrl);

      // Enable dropdown buttons (just in case)
      ['windows', 'mac', 'linux'].forEach(os => {
        document.querySelector(`[data-dropdown-btn="${os}"]`)?.classList.remove('opacity-50', 'cursor-not-allowed');
      });

    } catch (err) {
      console.error(err);
      versionEl.textContent = 'Версия неизвестна';
      enableBtn(btnWin, FALLBACK_URL);
      enableBtn(btnWinNsis, FALLBACK_URL);
      enableBtn(btnMac, FALLBACK_URL);
      enableBtn(btnMacIntel, FALLBACK_URL);
      enableBtn(btnMacTar, FALLBACK_URL);
      enableBtn(btnLinAppImg, FALLBACK_URL);
      enableBtn(btnLinDeb, FALLBACK_URL);
      enableBtn(btnLinRpm, FALLBACK_URL);
    }
  }

  fetchVersion();
</script>

<script is:inline>
  // Dropdown Logic
  document.addEventListener('click', (e) => {
    const isDropdownBtn = e.target.closest('[data-dropdown-btn]');
    const openMenu = document.querySelector('[data-dropdown-menu]:not(.hidden)');

    // Toggle logic
    if (isDropdownBtn) {
      const type = isDropdownBtn.getAttribute('data-dropdown-btn');
      const menu = document.querySelector(`[data-dropdown-menu="${type}"]`);
      
      if (menu) {
        menu.classList.toggle('hidden');
        if (openMenu && openMenu !== menu) openMenu.classList.add('hidden');
      }
      return;
    }

    // Close on outside click
    if (openMenu && !e.target.closest('[data-dropdown-menu]')) {
      openMenu.classList.add('hidden');
    }
  });
  // Отслеживаем клики по кнопкам скачивания
  document.addEventListener('click', async (e) => {
    const downloadBtn = e.target.closest('a[href*="github.com"], a[href*="releases"]');
    if (downloadBtn) {
      try {
        const { trackDownload } = await import('/src/utils/analytics.ts');
        const osMatch = downloadBtn.id?.match(/btn-(windows|mac|linux)/);
        const platform = osMatch ? osMatch[1] : 'unknown';
        await trackDownload(platform);
      } catch {}
    }
  });
</script>
