---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
---

<BaseLayout title="SectLauncher — лаунчер Minecraft" description="Моды, профили и авто‑обновления в один клик.">
  <Fragment slot="header">
    <Header />
  </Fragment>
  <Fragment slot="head">
    <link rel="canonical" href="https://sectlauncher.byteflipper.com/ru/" />
    <link rel="alternate" hreflang="en" href="https://sectlauncher.byteflipper.com/en/" />
    <link rel="preload" as="image" href="/screenshots/sectlauncher_home.png" />
  </Fragment>

  <section class="hero-bg">
    <div class="mx-auto max-w-6xl px-4 pt-16 pb-14 grid md:grid-cols-2 gap-10 items-center">
      <div>
        <h1 class="text-4xl md:text-5xl font-extrabold leading-tight">
          SectLauncher — современный Minecraft лаунчер
        </h1>
        <p class="mt-4 text-neutral-300 text-lg">
          Управляй модами, создавай профили и обновляй игру одной кнопкой. Просто запускай — всё остальное за тебя.
        </p>
        <div class="mt-4 inline-flex items-center px-3 py-2 rounded-lg bg-emerald-500/10 border border-emerald-500/20">
          <span class="text-emerald-400 font-medium text-sm flex items-center gap-2">
            <div class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></div>
            Доступна новая версия
          </span>
        </div>
        <div class="mt-6 flex flex-wrap items-center gap-3">
          <a href="/ru/download" class="px-5 py-3 rounded-md font-semibold text-emerald-900 bg-emerald-500 hover:bg-emerald-400 transition-colors shadow-sm inline-flex items-center gap-2">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z"/></svg>
            Скачать лаунчер
          </a>
          <a href="https://github.com/byteflipper-58/sectlauncher" class="px-5 py-3 rounded-md border border-neutral-700 hover:bg-neutral-800 transition-colors">GitHub</a>
          <a href="https://t.me/sectlauncher" class="px-5 py-3 rounded-md border border-neutral-700 hover:bg-neutral-800 transition-colors">Telegram</a>
        </div>
        <div class="mt-3 text-xs text-neutral-400">
          Доступно для Windows, macOS и Linux
        </div>
      </div>
      <div class="relative">
        <img
          src="/screenshots/sectlauncher_home.png"
          alt="Интерфейс SectLauncher"
          width="1024"
          height="640"
          fetchpriority="high"
          decoding="async"
          class="w-full h-auto object-contain transition-transform duration-500 hover:scale-[1.02]"
        />
      </div>
    </div>
  </section>
  <div aria-hidden="true" class="relative">
    <div class="mx-auto max-w-6xl px-4">
      <div class="h-px bg-gradient-to-r from-transparent via-neutral-800 to-transparent"></div>
    </div>
  </div>

  <!-- Новая секция с демонстрацией возможностей -->
  <section class="mx-auto max-w-6xl px-4 py-24 space-y-32">
    <!-- Блок 1: Нативность и производительность -->
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <div class="order-2 md:order-1">
        <img
          src="/screenshots/sectlauncher_home.png"
          alt="Главный экран SectLauncher"
          width="800"
          height="500"
          class="w-full h-auto object-contain transition-transform duration-500 hover:scale-[1.02]"
        />
      </div>
      <div class="order-1 md:order-2 space-y-6">
        <h2 class="text-3xl md:text-4xl font-black uppercase tracking-tight text-white leading-none">
          Нативная мощь <span class="text-orange-500">Rust</span>
        </h2>
        <p class="text-neutral-400 text-lg leading-relaxed">
          SectLauncher переписан на Rust с использованием Tauri v2. Это дает молниеносный запуск, минимальное потребление ресурсов и нативную производительность на Windows, Mac и Linux.
        </p>
        <ul class="space-y-3 text-neutral-300">
          <li class="flex items-center gap-3">
            <div class="w-1.5 h-1.5 bg-orange-500"></div>
            Мгновенный отклик интерфейса
          </li>
          <li class="flex items-center gap-3">
            <div class="w-1.5 h-1.5 bg-orange-500"></div>
            Минимальный вес приложения
          </li>
          <li class="flex items-center gap-3">
            <div class="w-1.5 h-1.5 bg-orange-500"></div>
            Безопасный нативный код
          </li>
        </ul>
      </div>
    </div>

    <!-- Блок 2: Моды и Инстансы -->
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <div class="space-y-6">
        <h2 class="text-3xl md:text-4xl font-black uppercase tracking-tight text-white leading-none">
          <span class="text-blue-500">Forge & Fabric</span> в один клик
        </h2>
        <p class="text-neutral-400 text-lg leading-relaxed">
          Больше не нужно мучиться с ручной установкой загрузчиков. SectLauncher автоматически скачивает и настраивает нужные версии игры и модов, создавая изолированные инстансы.
        </p>
        <ul class="space-y-3 text-neutral-300">
          <li class="flex items-center gap-3">
            <div class="w-1.5 h-1.5 bg-blue-500"></div>
            Автоматическая установка Forge/Fabric
          </li>
          <li class="flex items-center gap-3">
            <div class="w-1.5 h-1.5 bg-blue-500"></div>
            Умная изоляция игровых миров
          </li>
          <li class="flex items-center gap-3">
            <div class="w-1.5 h-1.5 bg-blue-500"></div>
            Официальная авторизация Microsoft
          </li>
        </ul>
      </div>
      <div>
        <img
          src="/screenshots/sectlauncher_instances.png"
          alt="Управление инстансами"
          width="800"
          height="500"
          class="w-full h-auto object-contain transition-transform duration-500 hover:scale-[1.02]"
        />
      </div>
    </div>

    <!-- Блок 3: Modrinth Integration -->
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <div class="order-2 md:order-1">
        <img
          src="/screenshots/sectlauncher_library.png"
          alt="Интеграция с Modrinth"
          width="800"
          height="500"
          class="w-full h-auto object-contain transition-transform duration-500 hover:scale-[1.02]"
        />
      </div>
      <div class="order-1 md:order-2 space-y-6">
        <h2 class="text-3xl md:text-4xl font-black uppercase tracking-tight text-white leading-none">
          Миллионы модов с <span class="text-green-500">Modrinth</span>
        </h2>
        <p class="text-neutral-400 text-lg leading-relaxed">
          Ищи, скачивай и устанавливай моды прямо в библиотеке. Благодаря глубокой интеграции с Modrinth, управление твоими дополнениями — это удобно и быстро.
        </p>
        <ul class="space-y-3 text-neutral-300">
          <li class="flex items-center gap-3">
            <div class="w-1.5 h-1.5 bg-green-500"></div>
            Поиск по всей базе Modrinth
          </li>
          <li class="flex items-center gap-3">
            <div class="w-1.5 h-1.5 bg-green-500"></div>
            Установка в один клик
          </li>
          <li class="flex items-center gap-3">
            <div class="w-1.5 h-1.5 bg-green-500"></div>
            Автоматическая проверка зависимостей
          </li>
        </ul>
      </div>
    </div>

    <!-- Блок 4: Детали мода -->
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <div class="space-y-6">
        <h2 class="text-3xl md:text-4xl font-black uppercase tracking-tight text-white leading-none">
          Полный <span class="text-cyan-500">контроль модов</span>
        </h2>
        <p class="text-neutral-400 text-lg leading-relaxed">
          Просматривай детали мода, выбирай любую доступную версию и обновляйся за секунды. Страница деталей дает всю необходимую информацию для тонкой настройки твоей игры.
        </p>
        <ul class="space-y-3 text-neutral-300">
          <li class="flex items-center gap-3">
            <div class="w-1.5 h-1.5 bg-cyan-500"></div>
            Выбор различных версий мода
          </li>
          <li class="flex items-center gap-3">
            <div class="w-1.5 h-1.5 bg-cyan-500"></div>
            Быстрое обновление до актуальной версии
          </li>
          <li class="flex items-center gap-3">
            <div class="w-1.5 h-1.5 bg-cyan-500"></div>
            Подробные описания и скриншоты
          </li>
        </ul>
      </div>
      <div>
        <img
          src="/screenshots/sectlauncher_mod_details.png"
          alt="Страница деталей мода"
          width="800"
          height="500"
          class="w-full h-auto object-contain transition-transform duration-500 hover:scale-[1.02]"
        />
      </div>
    </div>

    <!-- Блок 5: Авторизация -->
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <div class="order-2 md:order-1">
        <img
          src="/screenshots/sectlauncher_account_profile.png"
          alt="Добавление аккаунта"
          width="800"
          height="500"
          class="w-full h-auto object-contain transition-transform duration-500 hover:scale-[1.02]"
        />
      </div>
      <div class="order-1 md:order-2 space-y-6">
        <h2 class="text-3xl md:text-4xl font-black uppercase tracking-tight text-white leading-none">
          Свобода <span class="text-rose-500">выбора аккаунта</span>
        </h2>
        <p class="text-neutral-400 text-lg leading-relaxed">
          Входи под своей официальной лицензией Microsoft для игры на любых серверах или создавай Offline-профили. Удобный менеджер позволяет легко переключаться между аккаунтами.
        </p>
        <ul class="space-y-3 text-neutral-300">
          <li class="flex items-center gap-3">
            <div class="w-1.5 h-1.5 bg-rose-500"></div>
            Официальная Microsoft-авторизация
          </li>
          <li class="flex items-center gap-3">
            <div class="w-1.5 h-1.5 bg-rose-500"></div>
            Быстрое создание Offline аккаунтов
          </li>
          <li class="flex items-center gap-3">
            <div class="w-1.5 h-1.5 bg-rose-500"></div>
            Безопасное хранение данных сессий
          </li>
        </ul>
      </div>
    </div>

    <!-- Блок 6: Сборки -->
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <div class="space-y-6">
        <h2 class="text-3xl md:text-4xl font-black uppercase tracking-tight text-white leading-none">
          Готовые <span class="text-yellow-500">Сборки</span>
        </h2>
        <p class="text-neutral-400 text-lg leading-relaxed">
          Создавай свои или устанавливай готовые модпаки. SectLauncher обеспечивает удобное управление каждой деталью твоей сборки, позволяя легко переключаться между ними.
        </p>
        <ul class="space-y-3 text-neutral-300">
          <li class="flex items-center gap-3">
            <div class="w-1.5 h-1.5 bg-yellow-500"></div>
            Поддержка популярных форматов модпаков
          </li>
          <li class="flex items-center gap-3">
            <div class="w-1.5 h-1.5 bg-yellow-500"></div>
            Простое управление модами в сборке
          </li>
          <li class="flex items-center gap-3">
            <div class="w-1.5 h-1.5 bg-yellow-500"></div>
            Быстрый импорт и экспорт
          </li>
        </ul>
      </div>
      <div>
        <img
          src="/screenshots/sectlauncher_modpack.png"
          alt="Управление сборками"
          width="800"
          height="500"
          class="w-full h-auto object-contain transition-transform duration-500 hover:scale-[1.02]"
        />
      </div>
    </div>

    <!-- Блок 7: Персонализация -->
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <div class="order-2 md:order-1">
        <img
          src="/screenshots/sectlauncher_personalization_settings.png"
          alt="Настройки персонализации"
          width="800"
          height="500"
          class="w-full h-auto object-contain transition-transform duration-500 hover:scale-[1.02]"
        />
      </div>
      <div class="order-1 md:order-2 space-y-6">
        <h2 class="text-3xl md:text-4xl font-black uppercase tracking-tight text-white leading-none">
          Твой лаунчер — <span class="text-purple-500">Твои правила</span>
        </h2>
        <p class="text-neutral-400 text-lg leading-relaxed">
          Персонализация — это не просто смена цвета. Настраивай акцентные цвета под свое настроение или загружай любые изображения на фон главного экрана. Сделай SectLauncher по‑настоящему своим.
        </p>
        <ul class="space-y-3 text-neutral-300">
          <li class="flex items-center gap-3">
            <div class="w-1.5 h-1.5 bg-purple-500"></div>
            Гибкая система тем оформления
          </li>
          <li class="flex items-center gap-3">
            <div class="w-1.5 h-1.5 bg-purple-500"></div>
            Кастомные изображения на фоне
          </li>
          <li class="flex items-center gap-3">
            <div class="w-1.5 h-1.5 bg-purple-500"></div>
            Минималистичный профессиональный вид
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Roadmap -> Функционал -->
  <section class="mx-auto max-w-6xl px-4 py-16">
    <div class="mb-12 border-l-4 border-blue-600 pl-5">
      <h2 class="text-4xl font-black tracking-tight uppercase text-white mb-1">Функционал лаунчера</h2>
      <p class="text-neutral-500 font-medium uppercase tracking-widest text-xs">Все возможности проекта в одном списке</p>
    </div>
    
    <div class="space-y-8">
      <!-- Реализовано -->
      <div>
        <div class="flex items-center gap-3 mb-8">
          <h3 class="text-xl font-bold text-emerald-500 uppercase tracking-tight">Реализовано</h3>
          <div class="flex-grow h-px bg-emerald-500/10"></div>
        </div>
        
        <ul class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-6">
          {[
            { title: "Ядро Rust & Tauri v2", desc: "Максимальная производительность и безопасность нативного кода." },
            { title: "Поддержка Win / Mac / Linux", desc: "Единый интерфейс и функционал на всех популярных ОС." },
            { title: "Интеграция Modrinth", desc: "Установка модов, шейдеров и ресурспаков прямо из лаунчера." },
            { title: "Система сборок", desc: "Создание и управление неограниченным количеством игровых профилей." },
            { title: "Система OTA-обновлений", desc: "Автоматическое получение патчей без переустановки." },
            { title: "Microsoft Auth", desc: "Безопасный вход через официальные сервисы Microsoft." },
            { title: "Fabric / Forge Support", desc: "Нативная поддержка самых популярных загрузчиков модов." },
            { title: "JVM & UI Themes", desc: "Гибкая настройка параметров и кастомизация вида." }
          ].map((item) => (
            <li class="group">
              <div class="flex items-start gap-3">
                <div class="mt-1.5 w-1.5 h-1.5 bg-emerald-500 flex-shrink-0"></div>
                <div>
                  <h4 class="text-base font-bold text-neutral-100 group-hover:text-emerald-400 transition-colors uppercase tracking-tight leading-tight">{item.title}</h4>
                  <p class="text-neutral-500 text-xs leading-relaxed mt-0.5">{item.desc}</p>
                </div>
              </div>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <Fragment slot="footer">
    <Footer />
  </Fragment>
</BaseLayout>

