---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
---

<BaseLayout title="SectLauncher — лаунчер Minecraft" description="Моды, профили и авто‑обновления в один клик.">
  <Fragment slot="header">
    <Header />
  </Fragment>
  <Fragment slot="head">
    <link rel="canonical" href="https://sectlauncher.byteflipper.com/ru/" />
    <link rel="alternate" hreflang="en" href="https://sectlauncher.byteflipper.com/en/" />
    <link rel="alternate" hreflang="x-default" href="https://sectlauncher.byteflipper.com/ru/" />
    <meta property="og:url" content="https://sectlauncher.byteflipper.com/ru/" />
    <link rel="preload" as="image" href="/blog/sectlauncher-2-0/launcher_home.png" />
  </Fragment>

  <section class="hero-bg">
    <div class="mx-auto max-w-6xl px-4 pt-16 pb-14 grid md:grid-cols-2 gap-10 items-center">
      <div>
        <h1 class="text-4xl md:text-5xl font-extrabold leading-tight">
          SectLauncher — современный Minecraft лаунчер
        </h1>
        <p class="mt-4 text-neutral-300 text-lg">
          Управляй модами, создавай профили и обновляй игру одной кнопкой. Просто запускай — всё остальное за тебя.
        </p>
        <div class="mt-4 inline-flex items-center px-3 py-2 rounded-lg bg-orange-500/20 border border-orange-500/30">
          <svg class="w-4 h-4 mr-2 text-orange-400" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/>
          </svg>
          <span class="text-orange-300 font-medium text-sm">Проект в активной разработке</span>
        </div>
        <div class="mt-6 flex flex-wrap items-center gap-3">
          <div class="px-5 py-3 rounded-md font-semibold text-orange-900 bg-orange-500 cursor-not-allowed opacity-75">
            В разработке
          </div>
          <a href="https://github.com/byteflipper-58/sectlauncher" class="px-5 py-3 rounded-md border border-neutral-700 hover:bg-neutral-800">GitHub</a>
          <a href="https://t.me/sectlauncher" class="px-5 py-3 rounded-md border border-neutral-700 hover:bg-neutral-800">Telegram</a>
        </div>
        <div class="mt-3 text-xs text-neutral-400">
          Скоро будет доступно для скачивания
        </div>
      </div>
      <div class="relative">
        <img
          src="/blog/sectlauncher-2-0/launcher_home.png"
          alt="Интерфейс SectLauncher"
          width="1024"
          height="640"
          fetchpriority="high"
          decoding="async"
          class="w-full h-auto object-contain transition-transform duration-500 hover:scale-[1.02]"
        />
      </div>
    </div>
  </section>
  <div aria-hidden="true" class="relative">
    <div class="mx-auto max-w-6xl px-4">
      <div class="h-px bg-gradient-to-r from-transparent via-neutral-800 to-transparent"></div>
    </div>
  </div>

  <!-- Новая секция с демонстрацией возможностей -->
  <section class="mx-auto max-w-6xl px-4 py-24 space-y-32">
    <!-- Блок 1: Нативность и производительность -->
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <div class="order-2 md:order-1">
        <img
          src="/blog/sectlauncher-2-0/launcher_home.png"
          alt="Главный экран SectLauncher"
          width="800"
          height="500"
          class="w-full h-auto object-contain transition-transform duration-500 hover:scale-[1.02]"
        />
      </div>
      <div class="order-1 md:order-2 space-y-6">
        <h2 class="text-3xl md:text-4xl font-black uppercase tracking-tight text-white leading-none">
          Нативная мощь <span class="text-orange-500">Rust</span>
        </h2>
        <p class="text-neutral-400 text-lg leading-relaxed">
          SectLauncher переписан на Rust с использованием Tauri v2. Это дает молниеносный запуск, минимальное потребление ресурсов и нативную производительность на Windows, Mac и Linux. Никакого лишнего веса — только чистая мощь.
        </p>
        <ul class="space-y-3 text-neutral-300">
          <li class="flex items-center gap-3">
            <div class="w-1.5 h-1.5 bg-orange-500"></div>
            Мгновенный отклик интерфейса
          </li>
          <li class="flex items-center gap-3">
            <div class="w-1.5 h-1.5 bg-orange-500"></div>
            Минимальный вес приложения
          </li>
          <li class="flex items-center gap-3">
            <div class="w-1.5 h-1.5 bg-orange-500"></div>
            Безопасный нативный код
          </li>
        </ul>
      </div>
    </div>

    <!-- Блок 2: Моды и Инстансы -->
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <div class="space-y-6">
        <h2 class="text-3xl md:text-4xl font-black uppercase tracking-tight text-white leading-none">
          <span class="text-blue-500">Forge & Fabric</span> в один клик
        </h2>
        <p class="text-neutral-400 text-lg leading-relaxed">
          Больше не нужно мучиться с ручной установкой загрузчиков. SectLauncher автоматически скачивает и настраивает нужные версии игры и модов, создавая изолированные инстансы.
        </p>
        <ul class="space-y-3 text-neutral-300">
          <li class="flex items-center gap-3">
            <div class="w-1.5 h-1.5 bg-blue-500"></div>
            Автоматическая установка Forge/Fabric
          </li>
          <li class="flex items-center gap-3">
            <div class="w-1.5 h-1.5 bg-blue-500"></div>
            Умная изоляция игровых миров
          </li>
          <li class="flex items-center gap-3">
            <div class="w-1.5 h-1.5 bg-blue-500"></div>
            Официальная авторизация Microsoft
          </li>
        </ul>
      </div>
      <div>
        <img
          src="/blog/sectlauncher-2-0/launcher_instances.png"
          alt="Управление инстансами"
          width="800"
          height="500"
          class="w-full h-auto object-contain transition-transform duration-500 hover:scale-[1.02]"
        />
      </div>
    </div>

    <!-- Блок 3: Персонализация -->
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <div class="order-2 md:order-1">
        <img
          src="/blog/sectlauncher-2-0/launcher_personalization.png"
          alt="Настройки персонализации"
          width="800"
          height="500"
          class="w-full h-auto object-contain transition-transform duration-500 hover:scale-[1.02]"
        />
      </div>
      <div class="order-1 md:order-2 space-y-6">
        <h2 class="text-3xl md:text-4xl font-black uppercase tracking-tight text-white leading-none">
          Твой лаунчер — <span class="text-purple-500">Твои правила</span>
        </h2>
        <p class="text-neutral-400 text-lg leading-relaxed">
          Персонализация — это не просто смена цвета. Настраивай акцентные цвета под свое настроение или загружай любые изображения на фон главного экрана. Сделай SectLauncher по‑настоящему своим.
        </p>
        <ul class="space-y-3 text-neutral-300">
          <li class="flex items-center gap-3">
            <div class="w-1.5 h-1.5 bg-purple-500"></div>
            Гибкая система тем оформления
          </li>
          <li class="flex items-center gap-3">
            <div class="w-1.5 h-1.5 bg-purple-500"></div>
            Кастомные изображения на фоне
          </li>
          <li class="flex items-center gap-3">
            <div class="w-1.5 h-1.5 bg-purple-500"></div>
            Минималистичный профессиональный вид
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Roadmap -->
  <section class="mx-auto max-w-6xl px-4 py-16">
    <div class="mb-12 border-l-4 border-blue-600 pl-5">
      <h2 class="text-4xl font-black tracking-tight uppercase text-white mb-1">Дорожная карта</h2>
      <p class="text-neutral-500 font-medium uppercase tracking-widest text-xs">Технический вектор развития проекта</p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-12">
      <!-- Left Column: Реализовано -->
      <div>
        <div class="flex items-center gap-3 mb-8">
          <h3 class="text-xl font-bold text-emerald-500 uppercase tracking-tight">Реализовано</h3>
          <div class="flex-grow h-px bg-emerald-500/10"></div>
        </div>
        
        <ul class="space-y-5">
          {[
            { title: "Ядро Rust & Tauri v2", desc: "Максимальная производительность и безопасность нативного кода." },
            { title: "Поддержка Win / Mac / Linux", desc: "Единый интерфейс и функционал на всех популярных ОС." },
            { title: "Система OTA-обновлений", desc: "Автоматическое получение патчей без переустановки." },
            { title: "Microsoft Auth", desc: "Безопасный вход через официальные сервисы Microsoft." },
            { title: "Fabric / Forge Support", desc: "Нативная поддержка самых популярных загрузчиков модов." },
            { title: "JVM & UI Themes", desc: "Гибкая настройка параметров и кастомизация вида." }
          ].map((item) => (
            <li class="group">
              <div class="flex items-start gap-3">
                <div class="mt-1.5 w-1.5 h-1.5 bg-emerald-500 flex-shrink-0"></div>
                <div>
                  <h4 class="text-base font-bold text-neutral-100 group-hover:text-emerald-400 transition-colors uppercase tracking-tight leading-tight">{item.title}</h4>
                  <p class="text-neutral-500 text-xs leading-relaxed mt-0.5">{item.desc}</p>
                </div>
              </div>
            </li>
          ))}
        </ul>
      </div>

      <!-- Right Column: В планах -->
      <div>
        <div class="flex items-center gap-3 mb-8">
          <h3 class="text-xl font-bold text-blue-500 uppercase tracking-tight">В планах</h3>
          <div class="flex-grow h-px bg-blue-500/10"></div>
        </div>

        <ul class="space-y-5">
          {[
            { title: "CurseForge / Modrinth", desc: "Прямая интеграция с крупнейшими базами модов." },
            { title: "Автообновление модпаков", desc: "Автоматическая синхронизация версий в ваших сборках." },
            { title: "Изоляция инстансов", desc: "Улучшенная песочница для разделения игровых профилей." },
            { title: "Менеджер ресурсов", desc: "Продвинутое управление памятью и ассетами игры." }
          ].map((item) => (
            <li class="group">
              <div class="flex items-start gap-3 text-neutral-400">
                <div class="mt-1.5 w-1.5 h-1.5 border border-blue-500 flex-shrink-0"></div>
                <div>
                  <h4 class="text-base font-bold text-neutral-300 group-hover:text-blue-400 transition-colors uppercase tracking-tight leading-tight">{item.title}</h4>
                  <p class="text-neutral-500 text-xs leading-relaxed mt-0.5">{item.desc}</p>
                </div>
              </div>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

        </div>
      </div>
    </div>
  </section>

  <Fragment slot="footer">
    <Footer />
  </Fragment>
</BaseLayout>

